{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yuki",
  "version": "1.0.1",
  "identifier": "com.fg.yuki",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "yuki",
        "width": 400,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,  
        "transparent": true,    
        "alwaysOnTop": true 
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"], 
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/whisper-cli"
    ],
    "resources": [
      "resources/ggml-base.bin",
      "bin/*.dll"
    ]
  }
}