{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "store:default",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-read-file",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-start-dragging",
    "core:window:allow-show",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$APPCONFIG/**"
        },
        {
          "path": "$APPLOCALDATA/**"
        },
        {
          "path": "$APPLOG"
        },
        {
          "path": "$APPLOG/**"
        }
      ]
    },
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bin/whisper-cli",
          "sidecar": true
        }
      ]
    },
    "dialog:default"
  ]
}